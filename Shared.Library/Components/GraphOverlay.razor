@using MudBlazor

@if (ShowGraph && IsDataValid)
{
    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 9999;">
        <MudPaper style="background-color:lightgrey" Class="pa-4">
            @if (!string.IsNullOrEmpty(FilterInfo))
            {
                <MudText Typo="Typo.subtitle2" Style="margin-bottom: 10px; text-align: center; font-weight: bold;">
                    Applied Filters
                </MudText>
                <MudText Typo="Typo.body2" Style="margin-bottom: 15px; text-align: center; white-space: pre-line;">
                    @FilterInfo
                </MudText>
            }
            <MudChart 
                style="background-color:lightgrey" 
                ChartType="ChartType.Pie" 
                InputData="@GraphData" 
                InputLabels="@GraphLabels" 
                Width="300px" 
                Height="300px" />
            <div style="background-color:lightgrey;display: flex; justify-content: flex-end;">
                <MudButton 
                    Variant="Variant.Text" 
                    Color="Color.Primary" 
                    @onclick="OnClose">
                    Close
                </MudButton>
            </div>
        </MudPaper>
    </div>
}

@code {
    [Parameter] public bool ShowGraph { get; set; }
    [Parameter] public double[] GraphData { get; set; } = Array.Empty<double>();
    [Parameter] public string[] GraphLabels { get; set; } = Array.Empty<string>();
    [Parameter] public string? FilterInfo { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private bool IsDataValid => GraphData != null && GraphLabels != null && 
                               GraphData.Length > 0 && GraphLabels.Length > 0 && 
                               GraphData.Length == GraphLabels.Length;
} 