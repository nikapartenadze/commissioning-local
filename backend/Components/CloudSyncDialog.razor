@using IO_Checkout_Tool.Services.Interfaces
@using MudBlazor
@inject ICloudSyncService CloudSyncService
@inject IPlcCommunicationService PlcCommunication
@inject IConfigurationService Configuration
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body1" Class="mb-4">
            This will save your compatible local changes to the cloud, then refresh with the latest data for subsystem @Configuration.SubsystemId.
        </MudText>
        
        <MudAlert Severity="Severity.Warning" Class="mb-4">
            Any conflicted local changes will be overwritten.
        </MudAlert>
    </DialogContent>
    
    <DialogActions>
        <MudButton OnClick="Cancel" 
                   Disabled="@_isSyncing">
            Cancel
        </MudButton>
        <MudButton Color="Color.Primary" 
                   Variant="Variant.Filled" 
                   OnClick="StartSync" 
                   Disabled="@_isSyncing"
                   Loading="@_isSyncing"
                   StartIcon="Icons.Material.Filled.CloudQueue"
                   Style="min-width: 140px;">
            Sync Data
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    
    private bool _isSyncing = false;
    
    private async Task StartSync()
    {
        if (_isSyncing) return;
        
        _isSyncing = true;
        StateHasChanged();
        
        try
        {
            // Step 1: Pause PLC operations
            Snackbar.Add("Pausing PLC operations...", Severity.Info);
            await PlcCommunication.PauseForCloudSyncAsync();
            
            // Step 2: Sync with cloud
            Snackbar.Add("Syncing data with cloud...", Severity.Info);
            var success = await CloudSyncService.TriggerFreshSyncAsync();

            if (success)
            {
                // Step 3: Resume PLC operations (this takes significant time)
                Snackbar.Add("Restarting PLC operations...", Severity.Info);
                await PlcCommunication.ResumeAfterCloudSyncAsync();
                
                // Step 4: Wait for PLC operations to fully complete
                Snackbar.Add("Finalizing PLC initialization...", Severity.Info);
                await WaitForPlcOperationsToComplete();
                
                // Show success notification
                Snackbar.Add($"Successfully synchronized data from cloud for subsystem {Configuration.SubsystemId}!", Severity.Success);
                
                // Close dialog after a short delay to ensure user sees the success message
                await Task.Delay(1500);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                // Resume PLC operations even if sync failed
                Snackbar.Add("Restoring PLC operations...", Severity.Warning);
                await PlcCommunication.ResumeAfterCloudSyncAsync();
                await WaitForPlcOperationsToComplete();
                
                // Show error notification
                Snackbar.Add("Failed to synchronize data from cloud. Please check your connection and try again.", Severity.Error);
                
                _isSyncing = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            // Resume PLC operations even if sync crashed
            try
            {
                Snackbar.Add("Recovering PLC operations...", Severity.Warning);
                await PlcCommunication.ResumeAfterCloudSyncAsync();
                await WaitForPlcOperationsToComplete();
            }
            catch (Exception resumeEx)
            {
                // Log but don't show error for resume failure
            }
            
            // Show error notification
            Snackbar.Add($"An error occurred while syncing data: {ex.Message}", Severity.Error);
            
            _isSyncing = false;
            StateHasChanged();
        }
    }
    
    private async Task WaitForPlcOperationsToComplete()
    {
        // Wait for PLC operations to actually complete (not just the method to return)
        var maxWaitTime = TimeSpan.FromSeconds(30); // Maximum wait time
        var pollInterval = TimeSpan.FromMilliseconds(500); // Check every 500ms
        var startTime = DateTime.UtcNow;
        
        while (PlcCommunication.Loading && (DateTime.UtcNow - startTime) < maxWaitTime)
        {
            await Task.Delay(pollInterval);
            StateHasChanged(); // Keep UI responsive
        }
        
        if (PlcCommunication.Loading)
        {
            // Still loading after max wait time - continue anyway
            Snackbar.Add("PLC operations taking longer than expected...", Severity.Warning);
            await Task.Delay(2000); // Give it a bit more time
        }
    }
    
    private void Cancel()
    {
        if (!_isSyncing)
        {
            MudDialog.Cancel();
        }
    }
} 