@using IO_Checkout_Tool.Services.Interfaces
@using MudBlazor
@inject IConfigurationService ConfigurationService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="@isValid">
            <MudTextField @bind-Value="@ip" 
                         Label="PLC IP Address" 
                         Required="true" 
                         RequiredError="IP address is required"
                         Validation="@(new Func<string, string?>(ValidateIp))"
                         HelperText="IP address of the PLC (e.g., 192.168.1.100)" />
            
            <MudTextField @bind-Value="@path" 
                         Label="PLC Path" 
                         Required="true" 
                         RequiredError="PLC path is required"
                         HelperText="PLC path (e.g., 1,0 or 1,2)" />
            
            <MudTextField @bind-Value="@subsystemId" 
                         Label="Subsystem ID" 
                         Required="true" 
                         RequiredError="Subsystem ID is required"
                         HelperText="Unique identifier for this subsystem" />
            
            <MudTextField @bind-Value="@remoteUrl" 
                         Label="Remote URL" 
                         Required="false"
                         Validation="@(new Func<string, string?>(ValidateUrl))"
                         HelperText="Cloud service URL (optional)" />
            
            <MudTextField @bind-Value="@apiPassword" 
                         Label="API Password" 
                         Required="false"
                         InputType="InputType.Password"
                         HelperText="Password for cloud API authentication (optional)" />
            
            @* <MudCheckBox T="bool" 
                        Value="@orderMode" 
                        ValueChanged="@((bool value) => { orderMode = value; StateHasChanged(); })"
                        Label="Order Mode" 
                        Color="Color.Primary"
                        Class="my-3" /> *@
            
            <MudCheckBox T="bool" 
                        Value="@disableWatchdog" 
                        ValueChanged="@((bool value) => { disableWatchdog = value; StateHasChanged(); })"
                        Label="Disable Watchdog" 
                        Color="Color.Primary"
                        Class="my-3" />
            
            <MudText Typo="Typo.h6" Class="mt-4 mb-2">Column Visibility</MudText>
            
            <MudCheckBox T="bool" 
                        Value="@showStateColumn" 
                        ValueChanged="@((bool value) => OnColumnVisibilityChanged(nameof(showStateColumn), value))"
                        Label="Show State Column" 
                        Color="Color.Primary"
                        Class="my-2" />
            
            <MudCheckBox T="bool" 
                        Value="@showResultColumn" 
                        ValueChanged="@((bool value) => OnColumnVisibilityChanged(nameof(showResultColumn), value))"
                        Label="Show Result Column" 
                        Color="Color.Primary"
                        Class="my-2" />
            
            <MudCheckBox T="bool" 
                        Value="@showTimestampColumn" 
                        ValueChanged="@((bool value) => OnColumnVisibilityChanged(nameof(showTimestampColumn), value))"
                        Label="Show Timestamp Column" 
                        Color="Color.Primary"
                        Class="my-2" />
            
            <MudCheckBox T="bool" 
                        Value="@showHistoryColumn" 
                        ValueChanged="@((bool value) => OnColumnVisibilityChanged(nameof(showHistoryColumn), value))"
                        Label="Show History Column" 
                        Color="Color.Primary"
                        Class="my-2" />
        </MudForm>
    </DialogContent>
    
    <DialogActions>
        <MudButton OnClick="Cancel" 
                   Disabled="@ConfigurationService.IsReinitializing">
            Cancel
        </MudButton>
        <MudButton Color="Color.Primary" 
                   Variant="Variant.Filled" 
                   OnClick="SaveAndReload" 
                   Disabled="@(ConfigurationService.IsReinitializing || !HasPlcSettingsChanged())"
                   Loading="@ConfigurationService.IsReinitializing"
                   StartIcon="Icons.Material.Filled.Save"
                   Style="min-width: 140px;">
            Save & Reload
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    
    private MudForm form = null!;
    private bool isValid;
    
    private string ip = string.Empty;
    private string path = string.Empty;
    private string subsystemId = string.Empty;
    private string remoteUrl = string.Empty;
    private string apiPassword = string.Empty;
    private bool orderMode = false;
    private bool disableWatchdog = false;
    
    // Column visibility settings
    private bool showStateColumn = true;
    private bool showResultColumn = true;
    private bool showTimestampColumn = true;
    private bool showHistoryColumn = true;
    
    // Original values for change tracking (PLC settings only)
    private string originalIp = string.Empty;
    private string originalPath = string.Empty;
    private string originalSubsystemId = string.Empty;
    private string originalRemoteUrl = string.Empty;
    private string originalApiPassword = string.Empty;
    private bool originalOrderMode = false;
    private bool originalDisableWatchdog = false;
    
    protected override async Task OnInitializedAsync()
    {
        // Force a fresh configuration load to ensure we have the latest values
        ConfigurationService.LoadConfiguration();
        
        // Small delay to ensure configuration is fully loaded
        await Task.Delay(50);
        
        // Load current configuration values
        ip = ConfigurationService.Ip;
        path = ConfigurationService.Path;
        subsystemId = ConfigurationService.SubsystemId;
        remoteUrl = ConfigurationService.RemoteUrl;
        apiPassword = ConfigurationService.ApiPassword;
        orderMode = ConfigurationService.OrderMode;
        disableWatchdog = ConfigurationService.DisableWatchdog;
        showStateColumn = ConfigurationService.ShowStateColumn;
        showResultColumn = ConfigurationService.ShowResultColumn;
        showTimestampColumn = ConfigurationService.ShowTimestampColumn;
        showHistoryColumn = ConfigurationService.ShowHistoryColumn;
        
        // Store original values for change tracking (PLC settings only)
        originalIp = ip;
        originalPath = path;
        originalSubsystemId = subsystemId;
        originalRemoteUrl = remoteUrl;
        originalApiPassword = apiPassword;
        originalOrderMode = orderMode;
        originalDisableWatchdog = disableWatchdog;
        
        // Force UI update to ensure binding
        StateHasChanged();
    }
    
    private async Task SaveAndReload()
    {
        try
        {
            // Check if another reinitialization is already in progress
            if (ConfigurationService.IsReinitializing)
            {
                Snackbar.Add("Another configuration update is already in progress. Please wait...", Severity.Warning);
                return;
            }

            // First save the configuration
            var success = await ConfigurationService.UpdateConfigurationAsync(
                ip, path, subsystemId, remoteUrl, apiPassword, orderMode, disableWatchdog, 
                showStateColumn, showResultColumn, showTimestampColumn, showHistoryColumn);
            
            if (!success)
            {
                Snackbar.Add("Failed to update configuration", Severity.Error);
                return;
            }
            
            // Reload the application with the new configuration
            // Button loading state provides visual feedback
            await ConfigurationService.ReinitializeApplicationAsync();
            
            Snackbar.Add($"Application reloaded successfully for subsystem {subsystemId}!", Severity.Success);
            
            // Close dialog after a short delay to ensure user sees the success message
            await Task.Delay(1500);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving configuration or reloading application: {ex.Message}", Severity.Error);
        }
    }
    
    private void Cancel()
    {
        MudDialog.Cancel();
    }
    
    private string? ValidateIp(string ipAddress)
    {
        if (string.IsNullOrWhiteSpace(ipAddress))
            return "IP address is required";
            
        if (System.Net.IPAddress.TryParse(ipAddress, out _))
            return null;
            
        return "Please enter a valid IP address";
    }
    
    private string? ValidateUrl(string url)
    {
        if (string.IsNullOrWhiteSpace(url))
            return null; // URL is optional
            
        if (Uri.TryCreate(url, UriKind.Absolute, out var uriResult) 
            && (uriResult.Scheme == Uri.UriSchemeHttp || uriResult.Scheme == Uri.UriSchemeHttps))
            return null;
            
        return "Please enter a valid URL (http:// or https://)";
    }
    
    private async Task OnColumnVisibilityChanged(string columnName, bool value)
    {
        // Update local variables
        switch (columnName)
        {
            case nameof(showStateColumn):
                showStateColumn = value;
                break;
            case nameof(showResultColumn):
                showResultColumn = value;
                break;
            case nameof(showTimestampColumn):
                showTimestampColumn = value;
                break;
            case nameof(showHistoryColumn):
                showHistoryColumn = value;
                break;
        }
        
        // Apply changes immediately to the configuration service
        ConfigurationService.UpdateColumnVisibility(showStateColumn, showResultColumn, showTimestampColumn, showHistoryColumn);
        
        // Save the UI settings to the config file (without requiring reload)
        await ConfigurationService.SaveUISettingsAsync();
        
        // Update the UI
        StateHasChanged();
    }
    
    private bool HasPlcSettingsChanged()
    {
        return ip != originalIp ||
               path != originalPath ||
               subsystemId != originalSubsystemId ||
               remoteUrl != originalRemoteUrl ||
               apiPassword != originalApiPassword ||
               orderMode != originalOrderMode ||
               disableWatchdog != originalDisableWatchdog;
    }
} 