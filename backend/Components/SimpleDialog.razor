@if (IsVisible)
{
    <div class="simple-dialog-overlay" @onclick="OnOverlayClick">
        <div class="simple-dialog-container" @onclick:stopPropagation="true">
            <div class="simple-dialog-header">
                <h3 class="simple-dialog-title">@Title</h3>
                <button class="simple-dialog-close" @onclick="Close">&times;</button>
            </div>
            <div class="simple-dialog-content">
                @if (!string.IsNullOrEmpty(Message))
                {
                    <p>@((MarkupString)Message)</p>
                }
                @ChildContent
            </div>
            <div class="simple-dialog-footer">
                @if (ShowOkButton)
                {
                    <button class="simple-dialog-btn simple-dialog-btn-primary" @onclick="OnOkClick">@OkText</button>
                }
                @if (ShowCancelButton)
                {
                    <button class="simple-dialog-btn simple-dialog-btn-secondary" @onclick="OnCancelClick">@CancelText</button>
                }
                @FooterContent
            </div>
        </div>
    </div>
}

<style>
    .simple-dialog-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 1000;
    }

    .simple-dialog-container {
        background: white;
        border-radius: 8px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        max-width: 500px;
        width: 90%;
        max-height: 80vh;
        overflow: auto;
        animation: dialogFadeIn 0.2s ease-out;
    }

    .simple-dialog-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 20px;
        border-bottom: 1px solid #e0e0e0;
        background-color: #f5f5f5;
        border-radius: 8px 8px 0 0;
    }

    .simple-dialog-title {
        margin: 0;
        font-size: 1.25rem;
        font-weight: 500;
        color: #333;
    }

    .simple-dialog-close {
        background: none;
        border: none;
        font-size: 24px;
        cursor: pointer;
        color: #666;
        padding: 0;
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 4px;
    }

    .simple-dialog-close:hover {
        background-color: #e0e0e0;
        color: #333;
    }

    .simple-dialog-content {
        padding: 20px;
        line-height: 1.5;
        color: #555;
    }

    .simple-dialog-footer {
        padding: 16px 20px;
        border-top: 1px solid #e0e0e0;
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        background-color: #fafafa;
        border-radius: 0 0 8px 8px;
    }

    .simple-dialog-btn {
        padding: 8px 16px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 14px;
        font-weight: 500;
        transition: background-color 0.2s;
    }

    .simple-dialog-btn-primary {
        background-color: #1976d2;
        color: white;
    }

    .simple-dialog-btn-primary:hover {
        background-color: #1565c0;
    }

    .simple-dialog-btn-secondary {
        background-color: #e0e0e0;
        color: #333;
    }

    .simple-dialog-btn-secondary:hover {
        background-color: #d0d0d0;
    }

    @@keyframes dialogFadeIn {
        from {
            opacity: 0;
            transform: scale(0.9);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string Title { get; set; } = "Dialog";
    [Parameter] public string Message { get; set; } = "";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? FooterContent { get; set; }
    [Parameter] public bool ShowOkButton { get; set; } = true;
    [Parameter] public bool ShowCancelButton { get; set; } = false;
    [Parameter] public string OkText { get; set; } = "OK";
    [Parameter] public string CancelText { get; set; } = "Cancel";
    [Parameter] public bool CloseOnOverlayClick { get; set; } = true;
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnOk { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task Close()
    {
        IsVisible = false;
        await OnClose.InvokeAsync();
        StateHasChanged();
    }

    private async Task OnOkClick()
    {
        await OnOk.InvokeAsync();
        // Don't call Close() here - let the service handle it
    }

    private async Task OnCancelClick()
    {
        await OnCancel.InvokeAsync();
        // Don't call Close() here - let the service handle it
    }

    private async Task OnOverlayClick()
    {
        if (CloseOnOverlayClick)
        {
            await Close();
        }
    }
} 