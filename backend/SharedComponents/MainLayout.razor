@using IO_Checkout_Tool.Services.Interfaces
@using IO_Checkout_Tool.Components
@using MudBlazor
@inject ISimpleDialogService SimpleDialogService
@inherits LayoutComponentBase
@implements IDisposable

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

@* Global MudBlazor configuration to prevent focus trap issues removed for now *@

<ErrorBoundary>
    <ChildContent>
        <MudLayout>
            @Body
        </MudLayout>
    </ChildContent>
    <ErrorContent Context="exception">
        <div class="mud-alert mud-alert-filled mud-alert-filled-error">
            <div class="mud-alert-message">
                An error occurred. Please refresh the page.
            </div>
        </div>
    </ErrorContent>
</ErrorBoundary>

@* Simple Dialog Component *@
<SimpleDialog IsVisible="@SimpleDialogService.IsVisible"
              Title="@SimpleDialogService.CurrentTitle"
              Message="@SimpleDialogService.CurrentMessage"
              ShowOkButton="@SimpleDialogService.ShowOkButton"
              ShowCancelButton="@SimpleDialogService.ShowCancelButton"
              OkText="@SimpleDialogService.OkText"
              CancelText="@SimpleDialogService.CancelText"
              OnOk="@(() => SimpleDialogService.HandleOk())"
              OnCancel="@(() => SimpleDialogService.HandleCancel())"
              OnClose="@(() => SimpleDialogService.HandleClose())" />

<style>
body {
        overflow: hidden;
    }
</style>

@code {
    protected override void OnInitialized()
    {
        SimpleDialogService.StateChanged += OnDialogStateChanged;
    }

    private void OnDialogStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        SimpleDialogService.StateChanged -= OnDialogStateChanged;
    }
}