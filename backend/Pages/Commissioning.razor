@page "/"
@using System.Net;
@using CsvHelper;
@using System.Globalization;
@using System.IO;
@using System.Net.Http;
@using Microsoft.AspNetCore.SignalR.Client;
@using System.IO.Compression;
@using Microsoft.EntityFrameworkCore;
@using System.Linq;
@using System.Diagnostics;
@using IO_Checkout_Tool.Services.Interfaces;
@using IO_Checkout_Tool.Components;
@using MudBlazor;

<LoadingOverlay IsLoading="@(PlcCommunication.Loading || Watchdog.Loading)" />

<GraphOverlay 
    ShowGraph="@AppState.UiState.ShowGraph"
    GraphData="@AppState.GraphState.Data"
    GraphLabels="@AppState.GraphState.Labels"
    OnClose="@(() => AppState.UiState.ShowGraph = false)" />

<IOTestToolbar 
    TestingStarted="@Watchdog.TestingStarted"
    WatchdogColor="@Watchdog.WatchdogColor"
    DisableTesting="@PlcCommunication.DisableTesting"
    ShowOrderModeButton="@Configuration.OrderMode"
    PassAnimation="@AppState.UiState.PassAnimation"
    IsCloudConnected="@_isCloudConnected"
    IsPlcConnected="@_isPlcConnected"
    OnToggleWatchdog="@(() => _ = Watchdog.ToggleWatchdogAsync())"
    OnShowGraph="@ShowGraph"
    OnDownloadCsv="@CsvDownload"
    OnShowHistory="@ShowAllHistory"
    OnToggleTable="@(() => AppState.UiState.ShowTable = !AppState.UiState.ShowTable)"
    OnPlcIconClick="@ShowConfigDialog"
    OnCloudIconClick="@OnCloudSyncClick" />

<TestControlView 
    ShowTestControl="@(!AppState.UiState.ShowTable)"
    IsOrderMode="@Configuration.OrderMode"
    TestingStarted="@Watchdog.TestingStarted"
    CurrentTestTag="@AppState.TestState.TestTag"
    TestButtonStyle="@AppState.UiState.TestButtonStyle"
    OnFireUp="@((tag) => FireUp(tag))"
    OnFireDown="@((tag) => FireDown(tag))"
    OnManualFail="@((tag) => ManualFail(tag))" />

<TestDataGrid 
    ShowDataGrid="@(AppState.UiState.ShowTable || !Configuration.OrderMode)"
    ShowOrderColumn="@Configuration.OrderMode"
    ShowOutputColumn="@(!Configuration.OrderMode)"
    ShowStateColumn="@Configuration.ShowStateColumn"
    ShowHzColumn="@Configuration.ShowHzColumn"
    ShowResultColumn="@Configuration.ShowResultColumn"
    ShowTimestampColumn="@Configuration.ShowTimestampColumn"
    ShowHistoryColumn="@Configuration.ShowHistoryColumn"
    TestingStarted="@Watchdog.TestingStarted"
    Items="@PlcCommunication.TagList"
    QuickFilter="@_quickFilter"
    RowStyleFunc="@_rowStyleFunc"
    TimestampSortBy="@_sortBy"
    ShowStateFilter="@AppState.FilterState.OpenStateFilter"
    ShowResultFilter="@AppState.FilterState.OpenResultFilter"
    StateFilterIcon="@AppState.FilterState.StateFilterIcon"
    ResultFilterIcon="@AppState.FilterState.ResultFilterIcon"
    StateFilterItems="@AppState.FilterState.StateItems"
    ResultFilterItems="@AppState.FilterState.ResultItems"
    OnOpenStateFilter="@(() => AppState.FilterState.OpenStateFilter = true)"
    OnCloseStateFilter="@(() => AppState.FilterState.OpenStateFilter = false)"
    OnResetStateFilter="@ResetStateFilter"
    OnStateFilterChanged="@((valueItem) => StateValuesChanged(valueItem.value, valueItem.item))"
    OnOpenResultFilter="@(() => AppState.FilterState.OpenResultFilter = true)"
    OnCloseResultFilter="@(() => AppState.FilterState.OpenResultFilter = false)"
    OnResetResultFilter="@ResetResultFilter"
    OnResultFilterChanged="@((valueItem) => ResultValuesChanged(valueItem.value, valueItem.item))"
    OnCommentChanged="@NewComment"
    OnManualFail="@ManualFail"
    OnClearRow="@ClearRow"
    OnShowHistory="@ShowTestHistory"
    OnEnableOutput="@EnableOutput"
    HzDisplayFunc="@(io => TagChangeFrequency.GetHz(io.Id).ToString("F2"))"
    HzSortBy="@_hzSortBy"
    ShowHzFilter="@AppState.FilterState.OpenHzFilter"
    HzFilterIcon="@AppState.FilterState.HzFilterIcon"
    HzFilterItems="@AppState.FilterState.HzItems"
    OnOpenHzFilter="@(() => AppState.FilterState.OpenHzFilter = true)"
    OnCloseHzFilter="@(() => AppState.FilterState.OpenHzFilter = false)"
    OnResetHzFilter="@ResetHzFilter"
    OnHzFilterChanged="@((valueItem) => HzValuesChanged(valueItem.value, valueItem.item))" />