# IO Checkout Tool - Environment Variables
# Copy this to .env.local and update with your actual values

# Database (SQLite - path relative to frontend/)
DATABASE_URL="file:./database.db"

# JWT secret for auth tokens (generate a random string for production)
JWT_SECRET_KEY="change-this-to-a-random-secret"

# WebSocket server port (tag reader broadcasts state changes here)
PLC_WS_PORT=3001

# WebSocket broadcast URL (derived from PLC_WS_PORT + 100)
# Only set this if you need a custom broadcast endpoint
# WS_BROADCAST_URL="http://localhost:3101/broadcast"

# Node environment
NODE_ENV="development"
NEXT_TELEMETRY_DISABLED="1"
