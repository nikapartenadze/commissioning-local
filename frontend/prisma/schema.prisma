// Prisma schema for local SQLite database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Project for organizing subsystems
model Project {
  id          Int         @id @default(autoincrement())
  name        String      @map("Name")
  description String?     @map("Description")
  createdAt   DateTime    @default(now()) @map("CreatedAt")
  updatedAt   DateTime?   @map("UpdatedAt")

  subsystems Subsystem[]

  @@map("Projects")
}

// Subsystem within a project
model Subsystem {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("ProjectId")
  name      String?  @map("Name")
  createdAt DateTime @default(now()) @map("CreatedAt")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ios     Io[]

  @@index([projectId], name: "idx_subsystems_projectid")
  @@map("Subsystems")
}

// I/O point for PLC testing
model Io {
  id                Int       @id @default(autoincrement())
  subsystemId       Int       @map("SubsystemId")
  name              String?   @map("Name")
  description       String?   @map("Description")
  result            String?   @map("Result")
  timestamp         String?   @map("Timestamp")
  comments          String?   @map("Comments")
  order             Int?      @map("Order")
  version           BigInt    @default(0) @map("Version")
  tagType           String?   @map("TagType")
  cloudSyncedAt     DateTime? @map("CloudSyncedAt")
  networkDeviceName String?   @map("NetworkDeviceName")

  subsystem     Subsystem     @relation(fields: [subsystemId], references: [id], onDelete: Cascade)
  testHistories TestHistory[]

  @@index([subsystemId], name: "idx_ios_subsystemid")
  @@index([result], name: "idx_ios_result")
  @@map("Ios")
}

// Audit trail of test results
model TestHistory {
  id          Int     @id @default(autoincrement())
  ioId        Int     @map("IoId")
  result      String? @map("Result")
  timestamp   String  @map("Timestamp")
  comments    String? @map("Comments")
  testedBy    String? @map("TestedBy")
  state       String? @map("State")
  failureMode String? @map("FailureMode")

  io Io @relation(fields: [ioId], references: [id], onDelete: Cascade)

  @@index([ioId])
  @@index([timestamp], name: "idx_testhistories_timestamp")
  @@map("TestHistories")
}

// User authentication with PIN
model User {
  id         Int      @id @default(autoincrement())
  fullName   String   @unique @map("FullName")
  pin        String   @map("Pin")
  isAdmin    Boolean  @default(false) @map("IsAdmin")
  isActive   Boolean  @default(true) @map("IsActive")
  createdAt  String   @map("CreatedAt")
  lastUsedAt String?  @map("LastUsedAt")

  @@map("Users")
}

// Offline queue for cloud sync
model PendingSync {
  id            Int      @id @default(autoincrement())
  ioId          Int      @map("IoId")
  inspectorName String?  @map("InspectorName")
  testResult    String?  @map("TestResult")
  comments      String?  @map("Comments")
  state         String?  @map("State")
  timestamp     DateTime? @map("Timestamp")
  createdAt     DateTime @default(now()) @map("CreatedAt")
  retryCount    Int      @default(0) @map("RetryCount")
  lastError     String?  @map("LastError")
  version       BigInt   @default(0) @map("Version")

  @@index([ioId], name: "idx_pendingsyncs_ioid")
  @@index([createdAt], name: "idx_pendingsyncs_createdat")
  @@map("PendingSyncs")
}

// Diagnostic troubleshooting steps for tag types
model TagTypeDiagnostic {
  tagType         String   @map("TagType")
  failureMode     String   @map("FailureMode")
  diagnosticSteps String   @map("DiagnosticSteps")
  createdAt       DateTime @default(now()) @map("CreatedAt")
  updatedAt       DateTime? @map("UpdatedAt")

  @@id([tagType, failureMode])
  @@map("TagTypeDiagnostics")
}

// Change requests from site to cloud (IO definition changes)
model ChangeRequest {
  id                Int       @id @default(autoincrement())
  ioId              Int?      @map("IoId")
  requestType       String    @map("RequestType")
  currentValue      String?   @map("CurrentValue")
  requestedValue    String?   @map("RequestedValue")
  structuredChanges String?   @map("StructuredChanges")
  reason            String    @map("Reason")
  requestedBy       String    @map("RequestedBy")
  status            String    @default("pending") @map("Status")
  createdAt         DateTime  @default(now()) @map("CreatedAt")
  updatedAt         DateTime? @map("UpdatedAt")
  reviewedBy        String?   @map("ReviewedBy")
  reviewNote        String?   @map("ReviewNote")
  cloudId           Int?      @map("CloudId")

  @@index([ioId], name: "idx_changerequests_ioid")
  @@index([status], name: "idx_changerequests_status")
  @@map("ChangeRequests")
}

// Network ring (DLR loop) — e.g., MCM09 loop through DPMs
model NetworkRing {
  id          Int       @id @default(autoincrement())
  subsystemId Int       @map("SubsystemId")
  name        String    @map("Name")           // e.g., "MCM09 DLR Ring"
  mcmName     String    @map("McmName")        // e.g., "MCM09"
  mcmIp       String?   @map("McmIp")          // e.g., "11.200.1.1"
  mcmTag      String?   @map("McmTag")         // PLC tag for MCM status
  createdAt   DateTime  @default(now()) @map("CreatedAt")

  nodes       NetworkNode[]

  @@index([subsystemId])
  @@map("NetworkRings")
}

// A node in a ring (DPM) — ordered by position in the ring
model NetworkNode {
  id            Int       @id @default(autoincrement())
  ringId        Int       @map("RingId")
  name          String    @map("Name")           // e.g., "NCP1_1_DPM1"
  position      Int       @map("Position")       // order in ring (1, 2, 3...)
  ipAddress     String?   @map("IpAddress")
  cableIn       String?   @map("CableIn")        // cable FROM previous node, e.g., "CBL01"
  cableOut      String?   @map("CableOut")       // cable TO next node, e.g., "CBL02"
  statusTag     String?   @map("StatusTag")      // PLC tag for ConnectionFaulted
  totalPorts    Int       @default(28) @map("TotalPorts")
  createdAt     DateTime  @default(now()) @map("CreatedAt")

  ring          NetworkRing @relation(fields: [ringId], references: [id], onDelete: Cascade)
  ports         NetworkPort[]

  @@index([ringId])
  @@map("NetworkNodes")
}

// A port on a DPM node — star topology connection to a device
model NetworkPort {
  id            Int       @id @default(autoincrement())
  nodeId        Int       @map("NodeId")
  portNumber    Int       @map("PortNumber")     // 1-28
  cableLabel    String?   @map("CableLabel")     // e.g., "CBL05"
  deviceName    String?   @map("DeviceName")     // e.g., "NCP1_3S_VFD1"
  deviceType    String?   @map("DeviceType")     // e.g., "VFD", "SIO", "FIO", "POINT_IO"
  deviceIp      String?   @map("DeviceIp")       // e.g., "11.200.1.20"
  statusTag     String?   @map("StatusTag")      // PLC tag for device connection status
  createdAt     DateTime  @default(now()) @map("CreatedAt")

  node          NetworkNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId])
  @@map("NetworkPorts")
}
