# Copy to .env (git-ignored) before `docker compose up`.

# Image tag to build/run. One versioned image per release, matching the
# vX.Y.Z tag discipline. Rollback = change this -> `docker compose up -d`.
IMAGE_TAG=2.39.16

# Signs/verifies operator JWTs. MUST be stable across restarts (a new value
# invalidates every issued token) and kept secret. Generate one with:
#   openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-a-long-random-hex-string
