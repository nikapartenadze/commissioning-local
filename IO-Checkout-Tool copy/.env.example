# IO Checkout Tool - Environment Configuration
# Copy this file to .env and configure as needed

# Environment mode (Development or Production)
# Development uses http://localhost:3000 for cloud sync
# Production uses https://commissioning.lci.ge for cloud sync
COMMISSIONING_ENVIRONMENT=Production

# Optional: Override the cloud URL completely (takes precedence over COMMISSIONING_ENVIRONMENT)
# COMMISSIONING_REMOTE_URL=https://custom-cloud-url.example.com

# Alternative environment variables that will also be checked:
# DOTNET_ENVIRONMENT=Development
# ASPNETCORE_ENVIRONMENT=Development
