{
  "name": "commissioning-battle-e2e",
  "private": true,
  "version": "0.1.0",
  "description": "Playwright browser E2E that drives the connected battle stack (field tool :13000 + cloud dashboard :13001) and asserts they stay in sync.",
  "type": "module",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "report": "playwright show-report playwright-report",
    "install:browsers": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0"
  }
}
